# Copy to `.env` and fill in values. `.env` is gitignored.

# Required for LLM fallback when the SymPy tool cannot answer.
GROQ_API_KEY=

# Browser origins allowed to call this API (comma-separated, no spaces required).
# Use * only for local development — set explicit origins in production.
# Examples:
#   CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#   CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=http://localhost:5173

# JSON-lines log for HTTP + agent flow (one JSON object per line).
LOG_FILE=logs/app.log
LOG_LEVEL=INFO
# Optional: include process id on each line (true/false).
# LOG_INCLUDE_PID=false

# Guardrails & evaluation
MAX_INPUT_CHARS=1000
MAX_LLM_OUTPUT_CHARS=5000

# Groq chat (when SymPy cannot answer).
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TEMPERATURE=0.7
# GROQ_TOP_P=1.0
# GROQ_MAX_COMPLETION_TOKENS=4096
# GROQ_FREQUENCY_PENALTY=0
# GROQ_PRESENCE_PENALTY=0
